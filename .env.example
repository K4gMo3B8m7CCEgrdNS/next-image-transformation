# URL for the imgproxy server
IMGPROXY_URL=http://imgproxy:8080

# Supabase private originals bucket access. Never expose the secret key in a browser app.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-sb-secret-key
SUPABASE_ORIGINALS_BUCKET=images-originals
SUPABASE_SIGNED_URL_EXPIRES_IN=60

# This should allow the Supabase project host that signed URLs come from.
ALLOWED_REMOTE_DOMAINS=your-project.supabase.co
